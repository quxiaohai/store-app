{
  "name": "vite-vue-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development EXEC_ENV=dev  node server",
    "build": "npm run build:client && npm run build:server",
    "build:client": "cross-env NODE_ENV=production EXEC_ENV=prod vite build --outDir dist/client",
    "build:server": "cross-env NODE_ENV=production EXEC_ENV=prod vite build --ssr src/views/app/entry-server.js --outDir dist/server",
    "preview": "cross-env NODE_ENV=production EXEC_ENV=prod node server"
  },
  "dependencies": {
    "async-validator": "^4.2.5",
    "common": "^0.2.5",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "sirv": "^3.0.2",
    "vue": "^3.5.32",
    "vue-router": "^5.1.0",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "axios": "^1.17.0",
    "cross-env": "^10.1.0",
    "js-cookie": "^3.0.8",
    "postcss-pxtorem": "^6.1.0",
    "sass": "^1.100.0",
    "vite": "^8.0.3"
  }
}
